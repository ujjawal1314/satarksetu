# ===== Neo4j Graph Database Configuration =====
# Optional: Configure Neo4j for production graph database
# If not configured, system will use NetworkX (in-memory) fallback

# Enable Neo4j (set to 'true' to use Neo4j, 'false' for NetworkX)
USE_NEO4J=true

# Neo4j Connection URI (default: bolt://localhost:7687)
NEO4J_URI=bolt://localhost:7687

# Neo4j Authentication
NEO4J_USER=neo4j
NEO4J_PASSWORD=cyberfin2024

